{
  "fontFamily": {
    "heading": "'Satoshi Variable', -apple-system, BlinkMacSystemFont, sans-serif",
    "body": "'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif",
    "mono": "'JetBrains Mono', 'SF Mono', 'Fira Code', monospace"
  },
  "fontSize": {
    "xs": "11px",
    "sm": "13px",
    "base": "14px",
    "md": "16px",
    "lg": "18px",
    "xl": "20px",
    "2xl": "24px",
    "3xl": "28px",
    "4xl": "36px",
    "5xl": "48px",
    "6xl": "64px"
  },
  "fontWeight": {
    "regular": 400,
    "medium": 500,
    "semibold": 600,
    "bold": 700
  },
  "lineHeight": {
    "tight": 1.2,
    "normal": 1.5,
    "relaxed": 1.6,
    "loose": 1.8
  },
  "letterSpacing": {
    "tight": "-0.025em",
    "normal": "0",
    "wide": "0.025em",
    "wider": "0.05em",
    "widest": "0.1em"
  }
}
