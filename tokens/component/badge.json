{
  "default": {
    "bg": "{bg.surface-3}",
    "text": "{text.secondary}",
    "border": "{border.subtle}",
    "radius": "{radii.full}",
    "font-size": "{fontSize.xs}",
    "font-weight": "{fontWeight.medium}",
    "padding": "2px 8px",
    "letter-spacing": "{letterSpacing.wide}"
  },
  "success": {
    "bg": "rgba(34, 197, 94, 0.12)",
    "text": "{status.success}",
    "border": "transparent"
  },
  "warning": {
    "bg": "rgba(234, 179, 8, 0.12)",
    "text": "{status.warning}",
    "border": "transparent"
  },
  "error": {
    "bg": "rgba(239, 68, 68, 0.12)",
    "text": "{status.error}",
    "border": "transparent"
  },
  "info": {
    "bg": "rgba(59, 130, 246, 0.12)",
    "text": "{status.info}",
    "border": "transparent"
  },
  "sizes": {
    "sm": { "font-size": "{fontSize.xs}", "padding": "1px 6px" },
    "md": { "font-size": "{fontSize.sm}", "padding": "2px 10px" }
  }
}
